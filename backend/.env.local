# Локальні налаштування для розробки
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=talentup
POSTGRES_PASSWORD=talentup
POSTGRES_DB=talentup

# Redis налаштування
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT та API ключі
JWT_SECRET_KEY=local-dev-secret-key-change-in-production
OAUTH_SESSION_SECRET=local-oauth-secret
OPENAI_API_KEY=your-openai-api-key-here

# Локальні URL
SERVER_ORIGIN=http://localhost:8001
FRONTEND_ORIGIN=http://localhost:5173

# Google OAuth (можна залишити пустим для локальної розробки)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Налаштування файлів
RESUME_UPLOAD_DIR=./uploads/resumes
MAX_PDF_SIZE_BYTES=5242880

# SMTP налаштування (можна залишити пустим для локальної розробки)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=True

# Celery налаштування
CELERY_ENABLED=0
